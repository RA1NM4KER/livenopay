# Supabase project URL, for both the dashboard and local sync.
SUPABASE_URL=https://your-project-ref.supabase.co

# Read-only dashboard key. Safe to configure in the deployed Next.js environment.
SUPABASE_ANON_KEY=your-supabase-anon-key

# Local sync key. Keep this off the browser and out of deployed public client env.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: only needed if adb is not on PATH and the default Android Studio path is not correct.
# ADB_PATH=/path/to/adb
